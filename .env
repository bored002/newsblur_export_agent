# --- NewsBlur Credentials ---
# Your standard NewsBlur login details
NEWSBLUR_USERNAME=your_username_here
NEWSBLUR_PASSWORD=your_password_here

# --- AI Model Provider ---
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-secret-key-here

# --- Optional Settings ---
# Set to 'debug' to see more detailed logs in the terminal
LOG_LEVEL=info